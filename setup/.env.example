# =====================================================
# Paperless-NGX – Umgebungsvariablen
# Diese Datei nach .env kopieren und Werte setzen.
# =====================================================

# Datenbank
POSTGRES_PASSWORD=changeme-strong-password

# Paperless Secret (mind. 50 Zeichen, zufällig)
# Generieren mit: openssl rand -base64 50
PAPERLESS_SECRET_KEY=changeme-generate-with-openssl-rand-base64-50

# Reverse Proxy / Public URL
PAPERLESS_URL=https://dms.example.com

# Admin-Account beim ersten Start
PAPERLESS_ADMIN_USER=admin
PAPERLESS_ADMIN_PASSWORD=changeme

# =====================================================
# M365 / Microsoft OAuth2 (Allauth)
# Erst setzen, nachdem die Entra App registriert ist.
# =====================================================
PAPERLESS_APPS=allauth.socialaccount.providers.microsoft

# JSON in einer Zeile – Werte aus der Entra App einsetzen
PAPERLESS_SOCIALACCOUNT_PROVIDERS={"microsoft":{"APPS":[{"provider_id":"microsoft","name":"Microsoft","client_id":"YOUR-CLIENT-ID","secret":"YOUR-CLIENT-SECRET","settings":{"tenant":"YOUR-TENANT-ID"}}],"SCOPE":["User.Read","Mail.Read","offline_access"]}}
